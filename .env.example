# ==============================================================================
# Telegram Social Agent Bot - Environment Configuration
# Copy this file to .env and fill in your actual credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# Telegram Configuration
# ------------------------------------------------------------------------------
# Get your bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# The ID of the private group chat the bot is allowed to participate in.
ALLOWED_CHAT_ID=-1001234567890

# ------------------------------------------------------------------------------
# Google Gemini API Keys (Account Pool - 3 Active / 2 Backup)
# These will be pooled and automatically rotated to balance rate limits.
# If an active key fails or gets rate-limited, the system falls back to backups.
# ------------------------------------------------------------------------------
# Active Keys
GEMINI_API_KEY_1=your_active_gemini_key_1
GEMINI_API_KEY_2=your_active_gemini_key_2
GEMINI_API_KEY_3=your_active_gemini_key_3

# Backup Keys
GEMINI_API_KEY_BACKUP_1=your_backup_gemini_key_1
GEMINI_API_KEY_BACKUP_2=your_backup_gemini_key_2

# ------------------------------------------------------------------------------
# OpenRouter Configuration (Model Router & Registry Discovery)
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ------------------------------------------------------------------------------
# Database & Memory Configuration
# ------------------------------------------------------------------------------
# Path to the SQLite database file for user profiles and long-term memory
DATABASE_URL=sqlite:///./data/memory.db
# Redis connection string for short-term memory buffer (optional)
REDIS_URL=

# ------------------------------------------------------------------------------
# System & Logging Settings
# ------------------------------------------------------------------------------
LOG_LEVEL=info
PORT=8080
